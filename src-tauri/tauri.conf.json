{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pulse",
  "version": "0.7.0",
  "identifier": "com.thien.pulse",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFOTJGNzRDMThFNDM4OEUKUldTT09PUVlUUGVTVHUyRXc1SFNNQXd0dGRCelNGd2lxZXlsbjdOZ2pYb0FBcm9jV2ZSRW5tQ2QK",
      "endpoints": [
        "https://github.com/thientran01/pulse/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pulse",
        "width": 380,
        "height": 440,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Thien Tran",
    "shortDescription": "Mini music player widget for Windows",
    "longDescription": "Always-on-top mini music player that reads and controls whatever is playing (Apple Music, Spotify, browsers) with synced lyrics and album-art adaptive accents.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
