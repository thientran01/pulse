{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Palette",
  "version": "0.7.3",
  "identifier": "com.thien.pulse",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFOTJGNzRDMThFNDM4OEUKUldTT09PUVlUUGVTVHUyRXc1SFNNQXd0dGRCelNGd2lxZXlsbjdOZ2pYb0FBcm9jV2ZSRW5tQ2QK",
      "endpoints": [
        "https://github.com/thientran01/palette/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Palette",
        "width": 380,
        "height": 440,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "img-src": "'self' data: https://i.scdn.co https://*.scdn.co https://*.spotifycdn.com",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self'",
        "script-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      },
      "devCsp": {
        "default-src": "'self'",
        "img-src": "'self' data: https://i.scdn.co https://*.scdn.co https://*.spotifycdn.com",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self'",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval'",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420",
        "object-src": "'none'"
      },
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Thien Tran",
    "shortDescription": "Mini music player widget for Windows",
    "longDescription": "Always-on-top mini music player that reads and controls whatever is playing (Apple Music, Spotify, browsers) with synced lyrics and album-art adaptive accents.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  }
}
